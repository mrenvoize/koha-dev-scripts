#!/usr/bin/env bash
# kd — Koha dev workflow wrapper
# Manages git worktrees and KTD instances for Koha feature development.

set -e

# ── helpers ───────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF

kd — Koha dev workflow wrapper

Usage:
    kd up  <name> [--plugin PATH] [--plugins] [--search-engine ENGINE]
                  [--selenium] [--smtp] [--sso] [--persistent-db] [--bz] [--tmux] [--track UPSTREAM]
    kd wt  <name> [--bz] [--track UPSTREAM]
    kd down <name> [--rm]
    kd tmux <name>
    kd shell <name> [--root] [--run 'cmd']
    kd logs <name>
    kd list
    kd branches
    kd proxy [start|stop|status]
    kd -h|--help

Commands:
    up        Create worktree (if needed) and start a KTD instance; --bz applies the
              bug's patches before booting; --tmux waits for KTD then opens tmux;
              --track UPSTREAM creates branch tracking an upstream ref (e.g. origin/master)
    wt        Create worktree only (no KTD); --bz applies the bug's patches;
              --track UPSTREAM creates branch tracking an upstream ref (e.g. origin/master)
    down      Stop a KTD instance (--rm also removes the worktree)
    tmux      Attach or create a tmux dev session for the feature
    shell     Drop into the KTD container shell
    logs      Follow the KTD container logs
    list      Show worktrees and their KTD container status
    branches  Table of local branches, worktrees, containers, and upstream tracking
    proxy     Manage the shared Traefik proxy (start|stop|status)

Environment:
    KOHA_DIR    Root of the Koha workspace (default: ~/Projects/koha)
    KTD_HOME    KTD checkout (default: \$KOHA_DIR/tooling/koha-testing-docker)

EOF
}

setup_env() {
    export KOHA_DIR="${KOHA_DIR:-$HOME/Projects/koha}"
    export KTD_HOME="${KTD_HOME:-$KOHA_DIR/tooling/koha-testing-docker}"
    export LOCAL_USER_ID="$(id -u)"
    export LOCAL_GROUP_ID="$(id -g)"
}

# Converts a branch name to a Docker-safe project name and exports KOHA_IMAGE.
# Versioned branches (NN.NN.TAG, e.g. 24.11.etf) → TAG+MAJOR (etf24), KOHA_IMAGE=24.11
# All other branches → unchanged, KOHA_IMAGE unset
resolve_name() {
    if [[ "$1" =~ ^([0-9]+)\.([0-9]+)\.(.+)$ ]]; then
        KTD_NAME="${BASH_REMATCH[3]}${BASH_REMATCH[1]}"
        export KOHA_IMAGE="${BASH_REMATCH[1]}.${BASH_REMATCH[2]}"
    else
        KTD_NAME="$1"
        unset KOHA_IMAGE
    fi
}

# Returns the DNS domain used by the Traefik proxy on this machine.
# On kohadev.home the wildcard DNS resolves *.kohadev.home; everywhere else
# fall back to *.localhost (which browsers resolve without any DNS).
_ktd_domain() {
    if getent hosts "kohadev.home" > /dev/null 2>&1; then
        echo "kohadev.home"
    else
        echo "localhost"
    fi
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_up() {
    local name="$1"; shift
    setup_env
    resolve_name "$name"

    local worktree="$KOHA_DIR/core/worktrees/$name"
    local bare="$KOHA_DIR/core/koha.git"
    local ktd_extra=()
    local plugin_path=""
    local apply_bz=0
    local open_tmux=0
    local track_upstream=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --plugin)
                plugin_path="$(realpath "$2")"
                ktd_extra+=(--single-plugin "$plugin_path")
                shift 2 ;;
            --plugins|--selenium|--smtp|--sso|--persistent-db)
                ktd_extra+=("$1"); shift ;;
            --search-engine)
                ktd_extra+=(--search-engine "$2"); shift 2 ;;
            --bz)   apply_bz=1; shift ;;
            --tmux) open_tmux=1; shift ;;
            --track)
                track_upstream="$2"; shift 2 ;;
            *) echo "unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [ ! -d "$bare" ]; then
        echo "error: bare repo not found at $bare" >&2
        echo "       set KOHA_DIR or check your layout" >&2
        exit 1
    fi

    if [ ! -d "$worktree" ]; then
        if git -C "$bare" show-ref --verify --quiet "refs/heads/$name"; then
            echo "branch $name exists — checking it out as a worktree"
            git -C "$bare" worktree add "$worktree" "$name"
        else
            if [ -n "$track_upstream" ]; then
                echo "creating new branch $name tracking $track_upstream"
                git -C "$bare" worktree add "$worktree" -b "$name" "$track_upstream"
                git -C "$worktree" branch --set-upstream-to="$track_upstream" "$name"
            else
                echo "creating new branch $name from main"
                git -C "$bare" worktree add "$worktree" -b "$name" main
            fi
        fi
    fi

    # Pre-create remember plugin log dir so hooks don't error on first run in a
    # fresh worktree (the shell opens the redirect before session-start can mkdir).
    mkdir -p "$worktree/.remember/logs"

    if [ "$apply_bz" -eq 1 ]; then
        local bz_num
        bz_num="$(_bz_from_name "$name")"
        if [ -z "$bz_num" ]; then
            echo "error: cannot extract bug number from '$name' (expected bug_NNNNN form)" >&2
            exit 1
        fi
        echo "applying bz $bz_num..."
        (cd "$worktree" && git bz apply "$bz_num")
    fi

    if ! docker ps --format '{{.Names}}' | grep -q '^proxy-proxy-1$'; then
        echo "starting ktd_proxy..."
        ktd_proxy --start
    fi

    export SYNC_REPO="$worktree"
    export KTD_INSTANCE="$KTD_NAME"
    cd "$worktree"

    echo "bringing up KTD instance: $KTD_NAME"
    ktd --proxy --name "$KTD_NAME" "${ktd_extra[@]}" up -d

    local domain container ready_marker
    domain="$(_ktd_domain)"
    container="${KTD_NAME}-koha-1"
    ready_marker="koha-testing-docker has started up and is ready to be enjoyed!"

    echo ""

    # Phase 1: wait for the container to enter running state (up to 60s)
    local p1_timeout=60 p1_elapsed=0
    printf "waiting for container '%s' to start" "$container"
    while ! docker ps --filter "name=^${container}$" --filter "status=running" \
            --format '{{.Names}}' 2>/dev/null | grep -q .; do
        local cstate
        cstate=$(docker inspect --format '{{.State.Status}}' "$container" 2>/dev/null)
        if [[ "$cstate" == "exited" || "$cstate" == "dead" ]]; then
            local exit_code
            exit_code=$(docker inspect --format '{{.State.ExitCode}}' "$container" 2>/dev/null)
            printf "\nerror: container exited (code %s) — run: kd logs %s\n" \
                "${exit_code:-?}" "$name" >&2
            exit 1
        fi
        if [ "$p1_elapsed" -ge "$p1_timeout" ]; then
            printf "\ntimeout: %s did not start within %ds\n" "$container" "$p1_timeout" >&2
            exit 1
        fi
        sleep 3; p1_elapsed=$((p1_elapsed + 3)); printf "."
    done
    printf " up (%ds)\n\n" "$p1_elapsed"

    # Phase 2: stream container logs until the ready marker appears or the
    # container exits.  Process substitution (not a pipe) keeps the while loop
    # in the current shell so break returns control immediately rather than
    # waiting for docker logs --follow to exit on its own.
    local ready=0

    echo "--- KTD startup logs -----------------------------------------------"
    while IFS= read -r line; do
        printf '%s\n' "$line"
        if [[ "$line" == *"$ready_marker"* ]]; then
            ready=1
            break
        fi
    done < <(docker logs --follow "$container" 2>&1)
    echo "--------------------------------------------------------------------"
    echo ""

    if [ "$ready" -eq 0 ]; then
        local exit_code
        exit_code=$(docker inspect --format '{{.State.ExitCode}}' "$container" 2>/dev/null)
        printf "error: container exited (code %s) — run: kd logs %s\n" \
            "${exit_code:-?}" "$name" >&2
        exit 1
    fi

    cat <<EOF
KTD instance '$KTD_NAME' is up.
  OPAC:     http://$KTD_NAME.$domain
  Staff:    http://$KTD_NAME-intra.$domain
  Worktree: $worktree
EOF
    [ -n "$plugin_path" ] && echo "  Plugin:   $plugin_path"

    if [ "$open_tmux" -eq 1 ]; then
        cmd_tmux "$name"
    fi
}

# Extracts a Bugzilla number from a branch name of the form bug_NNNNN[-suffix].
_bz_from_name() {
    if [[ "$1" =~ bug_([0-9]+) ]]; then
        echo "${BASH_REMATCH[1]}"
    fi
}

_format_tracking() {
    local upstream="$1" track="$2"
    if [ -z "$upstream" ]; then
        echo "(local only)"; return
    fi
    if [[ "$track" == *"gone"* ]]; then
        echo "$upstream (gone)"; return
    fi
    local ahead="" behind="" status=""
    [[ "$track" =~ ahead\ ([0-9]+) ]]  && ahead="${BASH_REMATCH[1]}"
    [[ "$track" =~ behind\ ([0-9]+) ]] && behind="${BASH_REMATCH[1]}"
    if [ -n "$ahead" ] && [ -n "$behind" ]; then
        status="ahead $ahead, behind $behind"
    elif [ -n "$ahead" ]; then
        status="ahead $ahead"
    elif [ -n "$behind" ]; then
        status="behind $behind"
    fi
    [ -n "$status" ] && echo "$upstream  $status" || echo "$upstream"
}

cmd_wt() {
    local name="$1"; shift
    setup_env

    local worktree="$KOHA_DIR/core/worktrees/$name"
    local bare="$KOHA_DIR/core/koha.git"
    local apply_bz=0
    local track_upstream=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --bz) apply_bz=1; shift ;;
            --track)
                track_upstream="$2"; shift 2 ;;
            *) echo "unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [ ! -d "$bare" ]; then
        echo "error: bare repo not found at $bare" >&2; exit 1
    fi

    if [ ! -d "$worktree" ]; then
        if git -C "$bare" show-ref --verify --quiet "refs/heads/$name"; then
            echo "branch $name exists — checking it out as a worktree"
            git -C "$bare" worktree add "$worktree" "$name"
        else
            if [ -n "$track_upstream" ]; then
                echo "creating new branch $name tracking $track_upstream"
                git -C "$bare" worktree add "$worktree" -b "$name" "$track_upstream"
                git -C "$worktree" branch --set-upstream-to="$track_upstream" "$name"
            else
                echo "creating new branch $name from main"
                git -C "$bare" worktree add "$worktree" -b "$name" main
            fi
        fi
    else
        echo "worktree already exists at $worktree"
    fi

    mkdir -p "$worktree/.remember/logs"

    if [ "$apply_bz" -eq 1 ]; then
        local bz_num
        bz_num="$(_bz_from_name "$name")"
        if [ -z "$bz_num" ]; then
            echo "error: cannot extract bug number from '$name' (expected bug_NNNNN form)" >&2
            exit 1
        fi
        echo "applying bz $bz_num..."
        (cd "$worktree" && git bz apply "$bz_num")
    fi

    echo ""
    echo "worktree ready: $worktree"
    echo "  cd $worktree"
    [ -n "$bz_num" ] || echo "  kd tmux $name   # to open a dev session"
}

cmd_branches() {
    setup_env
    local bare="$KOHA_DIR/core/koha.git"
    local worktree_dir="$KOHA_DIR/core/worktrees"

    [ -d "$bare" ] || { echo "error: bare repo not found at $bare" >&2; exit 1; }

    # Build worktree lookup
    declare -A wt_set
    if [ -d "$worktree_dir" ]; then
        for wt in "$worktree_dir"/*/; do
            [ -d "$wt" ] && wt_set["$(basename "$wt")"]=1
        done
    fi

    printf "%-45s  %-40s  %s\n" "BRANCH" "KTD" "TRACKING"
    printf "%-45s  %-40s  %s\n" \
        "$(printf '%.0s-' {1..45})" \
        "$(printf '%.0s-' {1..40})" \
        "--------"

    declare -A seen_local

    while IFS='|' read -r branch upstream track; do
        seen_local["$branch"]=1

        local ktd="-"
        if [ "${wt_set[$branch]+x}" ]; then
            resolve_name "$branch"
            local cname="${KTD_NAME}-koha-1"
            local cstatus
            cstatus="$(docker ps -a --filter "name=^${cname}$" --format '{{.Status}}' 2>/dev/null)"
            if [ -n "$cstatus" ]; then
                ktd="${cname} (${cstatus})"
            else
                ktd="(no container)"
            fi
        fi

        local tracking
        tracking="$(_format_tracking "$upstream" "$track")"
        printf "%-45s  %-40s  %s\n" "$branch" "$ktd" "$tracking"
    done < <(git -C "$bare" for-each-ref \
        --sort=refname \
        --format='%(refname:short)|%(upstream:short)|%(upstream:track)' \
        refs/heads/)

    # Remote-only branches
    local remote_header_shown=0
    while read -r rbranch; do
        [ "${seen_local[$rbranch]+x}" ] && continue
        if [ "$remote_header_shown" -eq 0 ]; then
            echo ""
            printf "%-45s  %-40s  %s\n" "REMOTE-ONLY BRANCHES" "" ""
            remote_header_shown=1
        fi
        printf "%-45s  %-40s  %s\n" "  origin/$rbranch" "-" "(remote only)"
    done < <(git -C "$bare" for-each-ref \
        --sort=refname \
        --format='%(refname:short)' \
        refs/remotes/origin/ \
        | sed 's|^origin/||' \
        | grep -v '^HEAD$')
}

cmd_down() {
    local name="$1"; shift
    setup_env
    resolve_name "$name"

    local remove_worktree="no"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rm) remove_worktree="yes"; shift ;;
            *) echo "unknown option: $1" >&2; exit 1 ;;
        esac
    done

    local worktree="$KOHA_DIR/core/worktrees/$name"

    echo "bringing down KTD instance: $KTD_NAME"
    ktd down "$KTD_NAME" || true

    if [ "$remove_worktree" = "yes" ] && [ -d "$worktree" ]; then
        echo "removing worktree $worktree"
        git -C "$KOHA_DIR/core/koha.git" worktree remove --force "$worktree" \
            || rm -rf "$worktree"
    fi

    echo "done."
}

cmd_tmux() {
    local name="$1"
    setup_env
    resolve_name "$name"

    local worktree="$KOHA_DIR/core/worktrees/$name"
    if [ ! -d "$worktree" ]; then
        echo "worktree $worktree does not exist; run: kd up $name" >&2
        exit 1
    fi

    local session="koha-$KTD_NAME"
    if tmux has-session -t "$session" 2>/dev/null; then
        exec tmux attach -t "$session"
    fi

    local tmux_env=(
        -e "KTD_INSTANCE=$KTD_NAME"
        -e "SYNC_REPO=$worktree"
    )

    # Window 1: container visibility — logs left, shell right
    tmux new-session -d -s "$session" -c "$worktree" -n "container" \
        "${tmux_env[@]}" "docker logs -f ${KTD_NAME}-koha-1"
    tmux split-window -h -t "$session:container" -c "$worktree" \
        "ktd --shell --name $KTD_NAME"
    tmux select-pane -t "$session:container.1"

    # Window 2: dev — claude left, empty term right
    tmux new-window -t "$session" -n "dev" -c "$worktree" "claude"
    tmux split-window -h -t "$session:dev" -c "$worktree"
    tmux select-pane -t "$session:dev.1"

    tmux select-window -t "$session:dev"
    exec tmux attach -t "$session"
}

cmd_shell() {
    local name="$1"; shift
    setup_env
    resolve_name "$name"

    local extra=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root)     extra+=(--root); shift ;;
            --run)      extra+=(--run "$2"); shift 2 ;;
            *) echo "unknown option: $1" >&2; exit 1 ;;
        esac
    done

    export SYNC_REPO="$KOHA_DIR/core/worktrees/$name"
    ktd --shell --name "$KTD_NAME" "${extra[@]}"
}

cmd_logs() {
    local name="$1"
    setup_env
    resolve_name "$name"

    export SYNC_REPO="$KOHA_DIR/core/worktrees/$name"
    ktd --logs --name "$KTD_NAME"
}

cmd_list() {
    setup_env

    local worktree_dir="$KOHA_DIR/core/worktrees"
    if [ ! -d "$worktree_dir" ]; then
        echo "no worktrees found at $worktree_dir" >&2
        exit 1
    fi

    printf "%-35s  %-25s  %s\n" "BRANCH" "CONTAINER" "STATUS"
    printf "%-35s  %-25s  %s\n" \
        "$(printf '%.0s-' {1..35})" \
        "$(printf '%.0s-' {1..25})" \
        "-------"

    for worktree in "$worktree_dir"/*/; do
        [ -d "$worktree" ] || continue
        local branch
        branch="$(basename "$worktree")"
        resolve_name "$branch"

        local container="${KTD_NAME}-koha-1"
        local status
        status="$(docker ps -a --filter "name=^${container}$" --format '{{.Status}}' 2>/dev/null)"
        [ -z "$status" ] && status="not found"

        printf "%-35s  %-25s  %s\n" "$branch" "$container" "$status"
    done
}

cmd_proxy() {
    setup_env
    case "${1:-status}" in
        start)  ktd_proxy --start ;;
        stop)   ktd_proxy --stop ;;
        status) ktd_proxy --status ;;
        *) echo "usage: kd proxy [start|stop|status]" >&2; exit 1 ;;
    esac
}

# ── dispatch ──────────────────────────────────────────────────────────────────

CMD="${1:-}"
[ $# -gt 0 ] && shift

case "$CMD" in
    up)       [ -n "$1" ] || { echo "usage: kd up <name> [options]" >&2; exit 1; }
              cmd_up "$@" ;;
    wt)       [ -n "$1" ] || { echo "usage: kd wt <name> [--bz NUM]" >&2; exit 1; }
              cmd_wt "$@" ;;
    down)     [ -n "$1" ] || { echo "usage: kd down <name> [--rm]" >&2; exit 1; }
              cmd_down "$@" ;;
    tmux)     [ -n "$1" ] || { echo "usage: kd tmux <name>" >&2; exit 1; }
              cmd_tmux "$@" ;;
    shell)    [ -n "$1" ] || { echo "usage: kd shell <name> [--root] [--run 'cmd']" >&2; exit 1; }
              cmd_shell "$@" ;;
    logs)     [ -n "$1" ] || { echo "usage: kd logs <name>" >&2; exit 1; }
              cmd_logs "$@" ;;
    list)     cmd_list ;;
    branches|br) cmd_branches ;;
    proxy)    cmd_proxy "$@" ;;
    -h|--help) usage ;;
    "") usage; exit 1 ;;
    *) echo "unknown command: $CMD" >&2; usage; exit 1 ;;
esac
